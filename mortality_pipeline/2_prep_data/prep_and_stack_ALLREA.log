. do prep_and_stack_ALLREA.do 

. /**************************************************************************
> * prep_and_stack_ALLREA.do
> * 
> * COMBINED: Preps per-product panels AND stacks into ALLREA
> *
> * Step 1: For each product, reads R-merged panel, applies filters,
> *         winsorizes, constructs FE IDs → saves panel_prepped_for_regressions
> _PRODUCT_aligned.dta
> * Step 2: Stacks all products into ALLREA panel
> *
> **************************************************************************/
. 
. clear all

. set more off

. 
. * ===========================================================================
> =
. * CONFIG — change resolution here only
. * ===========================================================================
> =
. 
. local resolution "1deg"   /* ← CHANGE: "025deg" or "1deg" */

. 
. global CODE "/user/ab5405/summeraliaclimate/code"

. 
. * R merge script outputs (input for Step 1)
. global ROUT   "$CODE/mortality_pipeline/prep_panels/`resolution'"

. 
. * Step 1 outputs / Step 2 inputs
. global OUTPUT "$CODE/mortality_pipeline/output_panels/`resolution'"

. capture mkdir "$OUTPUT"

. 
. local products GMFD ERA5_025 JRA_3Q MERRA2

. 
. di ""


. di "========================================================================"
========================================================================

. di "CONFIGURATION:"
CONFIGURATION:

. di "  Resolution:  `resolution'"
  Resolution:  1deg

. di "  R panels in: $ROUT"
  R panels in: /user/ab5405/summeraliaclimate/code/mortality_pipeline/prep_pane
> ls/1deg

. di "  Output dir:  $OUTPUT"
  Output dir:  /user/ab5405/summeraliaclimate/code/mortality_pipeline/output_pa
> nels/1deg

. di "========================================================================"
========================================================================

. di ""


. 
. * ===========================================================================
> =
. * STEP 1 — Prep each product panel
. * ===========================================================================
> =
. 
. foreach product of local products {
  2. 
.     local inpanel  "$ROUT/global_mortality_panel_public_`product'.dta"
  3.     local outpanel "$OUTPUT/panel_prepped_for_regressions_`product'_aligne
> d.dta"
  4. 
.     capture confirm file "`inpanel'"
  5.     if _rc {
  6.         di as yellow "⚠️  Not found: `inpanel' (skipping `product')"
  7.         continue
  8.     }
  9. 
.     di ""
 10.     di "------------------------------------------------------------------
> --"
 11.     di "STEP 1: Prepping `product'"
 12.     di "------------------------------------------------------------------
> --"
 13. 
.     use "`inpanel'", clear
 14. 
.     * 0a) Coerce agegroup to string
.     capture confirm numeric variable agegroup
 15.     if !_rc {
 16.         capture decode agegroup, gen(age_s)
 17.         if !_rc {
 18.             drop agegroup
 19.             rename age_s agegroup
 20.         }
 21.     }
 22.     replace agegroup = strtrim(agegroup)
 23. 
.     * 0b) Build 'total' age group
.     preserve
 24.         keep if inlist(agegroup,"0-4","5-64","65+")
 25.         collapse (sum) deaths population, by(iso adm1_id adm2_id year)
 26.         gen agegroup = "total"
 27.         tempfile total
 28.         save `total'
 29.     restore
 30.     append using `total'
 31. 
.     * 1) Recompute raw deathrate
.     capture drop deathrate
 32.     gen deathrate = (deaths / population) * 100000
 33. 
.     * 2) Sample filters
.     gen sample = 1
 34.     replace sample = 0 if year > 2010
 35.     replace sample = 0 if mi(tavg_poly_1_`product')
 36.     replace sample = 0 if mi(prcp_poly_1_`product')
 37.     replace sample = 0 if mi(loggdppc_adm1_avg)
 38.     replace sample = 0 if mi(lr_tavg_`product'_adm1_avg)
 39.     keep if sample==1
 40.     drop sample
 41. 
.     * 3) Winsorize deathrate at 99th pctile within iso×agegroup
.     bysort iso agegroup: egen deathrate_p99 = pctile(deathrate), p(99)
 42.     gen deathrate_w99 = cond(deathrate > deathrate_p99 & !mi(deathrate), d
> eathrate_p99, deathrate)
 43.     drop deathrate_p99
 44. 
.     * 4) FE IDs
.     egen adm0_code        = group(iso)
 45.     egen adm1_code        = group(iso adm1_id)
 46.     replace adm2_id       = adm1_id if iso == "JPN"
 47.     egen adm2_code        = group(iso adm1_id adm2_id)
 48.     egen adm0_agegrp_code = group(iso agegroup)
 49.     egen adm1_agegrp_code = group(iso adm1_id agegroup)
 50. 
.     * 5) adm0_code2 (EU pooled)
.     gen adm0_code2 = 41
 51.     replace adm0_code2 = 4  if adm0_code == 4
 52.     replace adm0_code2 = 6  if adm0_code == 6
 53.     replace adm0_code2 = 7  if adm0_code == 7
 54.     replace adm0_code2 = 15 if adm0_code == 15
 55.     replace adm0_code2 = 23 if adm0_code == 23
 56.     replace adm0_code2 = 27 if adm0_code == 27
 57.     replace adm0_code2 = 40 if adm0_code == 40
 58. 
.     gen iso2 = iso
 59.     replace iso2 = "EUR" if adm0_code2==41
 60. 
.     * 6) China time series flag
.     gen CHN_ts = 1
 61.     replace CHN_ts = 2 if year >= 2004 & iso=="CHN"
 62. 
.     * 7) Rename product-specific vars to generic names
.     capture confirm variable tavg_poly_1_`product'
 63.     if !_rc {
 64.         rename tavg_poly_1_`product' tavg_poly_1
 65.         capture rename tavg_poly_2_`product' tavg_poly_2
 66.         capture rename tavg_poly_3_`product' tavg_poly_3
 67.         capture rename tavg_poly_4_`product' tavg_poly_4
 68.     }
 69.     capture confirm variable prcp_poly_1_`product'
 70.     if !_rc {
 71.         rename prcp_poly_1_`product' prcp_poly_1
 72.         capture rename prcp_poly_2_`product' prcp_poly_2
 73.     }
 74.     capture confirm variable lr_tavg_`product'_adm1_avg
 75.     if !_rc {
 76.         rename lr_tavg_`product'_adm1_avg lr_tavg_adm1_avg
 77.     }
 78. 
.     * 8) Save
.     save "`outpanel'", replace
 79.     di as res "✅ Saved: `outpanel'"
 80.     di "   Observations: " _N
 81. }

