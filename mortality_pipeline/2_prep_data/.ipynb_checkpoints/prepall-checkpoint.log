. do prepall.do 

. /**************************************************************************
> * prep_panel_ALL_aligned.do
> * - Builds 'total' agegroup from bins (important!)
> * - Applies sample filters
> * - Winsorizes deathrate within iso×agegroup (AFTER filtering, correct order)
> * - Constructs FE IDs
> * - Loops over observational products: ERA5_025, JRA_3Q, MERRA2, GMFD
> **************************************************************************/
. 
. * CONFIG
. local resolution "1deg"  /* ← CHANGE THIS */

. 
. * Input/output directories include resolution
. global PANELS  "$CODE/mortality_pipeline/prep_panels/`resolution'"

. global OUTPUT  "$CODE/mortality_pipeline/output_panels/`resolution'"

. capture mkdir "$OUTPUT"

. 
. local products GMFD ERA5 JRA_3Q MERRA2 

. 
. foreach product of local products {
  2. 
.     * Define input/output paths
.     local inpanel  "$CODE/regressions/prep_panels/global_mortality_panel_publ
> ic_`product'.dta"
  3.     local outpanel "$OUTPUT/panel_prepped_for_regressions_`product'_aligne
> d.dta"
  4. 
.     di "Processing `product' ..."
  5.     use "`inpanel'", clear
  6. 
.     * 0a) Coerce agegroup to string if it was stored as a numeric/labelled va
> riable.
.     * Downstream collapse and inlist() calls require string format.
.     capture confirm numeric variable agegroup
  7.     if !_rc {
  8.         capture decode agegroup, gen(age_s)
  9.         if !_rc {
 10.             drop agegroup
 11.             rename age_s agegroup
 12.         }
 13.     }
 14.     replace agegroup = strtrim(agegroup)
 15. 
.     * 0b) Construct a 'total' age group by summing deaths and population acro
> ss
.     *     the three age bins (0-4, 5-64, 65+). This is appended as a new set 
> of
.     *     rows so that regressions can be run on all-age mortality as well as
.     *     age-specific mortality using the same panel structure.
.     preserve
 16.         keep if inlist(agegroup,"0-4","5-64","65+")
 17.         collapse (sum) deaths population, by(iso adm1_id adm2_id year)
 18.         gen agegroup = "total"
 19.         tempfile total
 20.         save `total'
 21.     restore
 22.     append using `total'
 23. 
.     * 1) Recompute raw deathrate
.     capture drop deathrate
 24.     gen deathrate = (deaths / population) * 100000
 25. 
.     * 2) Apply sample filters. Observations are dropped if:
.     *    - year > 2010: restricts to the 1981-2010 baseline estimation window
.     *    - tavg/prcp poly missing: no climate data available for that ADM2-ye
> ar
.     *    - loggdppc missing: required control variable absent
.     *    - lr_tavg missing: long-run temperature average (needed for climate 
> response heterogeneity) absent
.     *    Comment out the prcp filter for products that do not include precipi
> tation (e.g. MERRA2).
.     gen sample = 1
 26.     replace sample = 0 if year > 2010
 27.     replace sample = 0 if mi(tavg_poly_1_`product')
 28.     * If precip missing is allowed, comment out the next line
.     replace sample = 0 if mi(prcp_poly_1_`product')
 29.     replace sample = 0 if mi(loggdppc_adm1_avg)
 30.     replace sample = 0 if mi(lr_tavg_`product'_adm1_avg)
 31. 
.     keep if sample==1
 32.     drop sample
 33. 
.     * 3) Winsorize deathrate at the 99th percentile within iso × agegroup cel
> ls.
.     *    This must happen AFTER sample filters are applied so that the p99 th
> reshold
.     *    is computed only on the estimation sample, not on observations that 
> will
.     *    be dropped anyway.
.     bysort iso agegroup: egen deathrate_p99 = pctile(deathrate), p(99)
 34.     gen deathrate_w99 = cond(deathrate > deathrate_p99 & !mi(deathrate), d
> eathrate_p99, deathrate)
 35.     drop deathrate_p99
 36. 
.     * 4) FE IDs
.     egen adm0_code          = group(iso)
 37.     egen adm1_code          = group(iso adm1_id)
 38.     replace adm2_id         = adm1_id if iso == "JPN"
 39.     egen adm2_code          = group(iso adm1_id adm2_id)
 40. 
.     egen adm0_agegrp_code   = group(iso agegroup)
 41.     egen adm1_agegrp_code   = group(iso adm1_id agegroup)
 42. 
.     * 5) Build adm0_code2, a country code that treats all EU countries as a s
> ingle
.     *    unit (code 41) while keeping non-EU countries at their own codes.
.     *    This mirrors the Carleton et al. aggregation where EU is pooled for
.     *    identification. iso is preserved unchanged for other uses.
.     gen adm0_code2 = 41
 43.     replace adm0_code2 = 4  if adm0_code == 4   // BRA
 44.     replace adm0_code2 = 6  if adm0_code == 6   // CHL
 45.     replace adm0_code2 = 7  if adm0_code == 7   // CHN
 46.     replace adm0_code2 = 15 if adm0_code == 15  // FRA
 47.     replace adm0_code2 = 23 if adm0_code == 23  // JPN
 48.     replace adm0_code2 = 27 if adm0_code == 27  // MEX
 49.     replace adm0_code2 = 40 if adm0_code == 40  // USA
 50. 
.     gen iso2 = iso
 51.     replace iso2 = "EUR" if adm0_code2==41
 52. 
.     * 6) Flag two sub-periods for China to account for a structural break in
.     *    mortality reporting around the 2004 administrative reform. CHN_ts=1
.     *    covers pre-2004 and CHN_ts=2 covers 2004 onward.
.     gen CHN_ts = 1
 53.     replace CHN_ts = 2 if year >= 2004 & iso=="CHN"
 54. 
.     * 7) Save aligned panel
.     save "`outpanel'", replace
 55.     di "Saved aligned panel for `product' → `outpanel'"
 56. 
.     clear
 57. }
Processing GMFD ...
file /regressions/prep_panels/global_mortality_panel_public_GMFD.dta not
    found
r(601);

end of do-file
r(601);
