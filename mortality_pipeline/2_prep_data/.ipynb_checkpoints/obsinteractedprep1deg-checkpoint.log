    /user/ab5405/summeraliaclimate/code/mortality_pipeline/prep_panels/1deg/pan
> el_prepped_for_regressions_MERRA2_aligned.dta
    (skipping)


. 
. * ===========================================================================
> =
. * CHECK AND SAVE
. * ===========================================================================
> =
. 
. capture confirm file `base'

. if _rc {
.     di as error ""

.     di as error "❌ ERROR: No product files were found!"
❌ ERROR: No product files were found!
.     di as error "   Location: $OUTPUT"
   Location: /user/ab5405/summeraliaclimate/code/mortality_pipeline/output_pane
> ls/1deg
.     di as error ""

.     di as error "Make sure you ran prep_panel_ALL_aligned_FLEXIBLE.do first!"
Make sure you ran prep_panel_ALL_aligned_FLEXIBLE.do first!
.     exit 1
--Break--
r(1);
. }
--Break--
r(1);

end of do-file
