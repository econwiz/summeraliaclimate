. do export_1deg_ALLREA_agespec_to_per_product_csvv.do 

. /**************************************************************************
> * CSVV GENERATOR — ALLREA pooled ster → per-product CSVVs
> * 1deg version
> *
> * Product encoding: 1=ERA5_025, 2=GMFD, 3=JRA_3Q, 4=MERRA2
> * Base category (product=1b) = ERA5_025
> *
> * 36 gammas per product: 3 ages × 4 polys × 3 covariates {1, LR, loginc}
> * Age codes: 1b=0-4, 2=5-64, 3=65+, 4=total (skip total in CSVV)
> **************************************************************************/
. 
. clear all

. set more off

. 
. global REPO "/user/ab5405/summeraliaclimate"

. 
. local STERFILE "$REPO/code/mortality_pipeline/output/1deg/age_spec_ALLREA/age
> spec_prod_interact_spec2_ALLREA_1deg.ster"

. local CSVVDIR  "$REPO/code/mortality_pipeline/output/1deg/age_spec_interacted
> _csvv"

. cap mkdir "`CSVVDIR'"

. 
. local prod_codes "1 2 3 4"

. local prod_names "ERA5_025 GMFD JRA_3Q MERRA2"

. local age_codes  "1 2 3"

. 
. estimates use "`STERFILE'"

. matrix B = e(b)

. matrix V = e(V)

. 
. di as res "Loaded: `STERFILE'"
Loaded: /user/ab5405/summeraliaclimate/code/mortality_pipeline/output/1deg/age_
> spec_ALLREA/agespec_prod_interact_spec2_ALLREA_1deg.ster

. di "N = " e(N)
N = 553487

. 
. forvalues pi = 1/4 {
  2. 
.     local prod_name : word `pi' of `prod_names'
  3.     local prod_code : word `pi' of `prod_codes'
  4. 
.     di ""
  5.     di "============================================================"
  6.     di "Building CSVV for product: `prod_name' (code=`prod_code')"
  7.     di "============================================================"
  8. 
.     local ncoef 36
  9.     matrix GAMMA = J(1, `ncoef', 0)
 10.     matrix GVCV  = J(`ncoef', `ncoef', 0)
 11. 
.     local idx 0
 12. 
.     foreach a of local age_codes {
 13.         forvalues k = 1/4 {
 14.             foreach slot in base lr loginc {
 15. 
.                 local ++idx
 16. 
.                 if "`slot'" == "base" {
 17.                     if `a' == 1 local base_nm "`a'b.agegroup#c.tavg_poly_`
> k'"
 18.                     else        local base_nm "`a'.agegroup#c.tavg_poly_`k
> '"
 19.                 }
 20.                 else if "`slot'" == "lr" {
 21.                     if `a' == 1 local base_nm "`a'b.agegroup#c.tavg_poly_`
> k'#c.lr_tavg_adm1_avg"
 22.                     else        local base_nm "`a'.agegroup#c.tavg_poly_`k
> '#c.lr_tavg_adm1_avg"
 23.                 }
 24.                 else {
 25.                     if `a' == 1 local base_nm "`a'b.agegroup#c.tavg_poly_`
> k'#c.loggdppc_adm1_avg"
 26.                     else        local base_nm "`a'.agegroup#c.tavg_poly_`k
> '#c.loggdppc_adm1_avg"
 27.                 }
 28. 
.                 if `pi' == 1 {
 29.                     local has_delta 0
 30.                     local id 0
 31.                 }
 32.                 else {
 33.                     local has_delta 1
 34.                     if "`slot'" == "base" {
 35.                         if `a' == 1 local delta_nm "`a'b.agegroup#`prod_co
> de'.product#c.tavg_poly_`k'"
 36.                         else        local delta_nm "`a'.agegroup#`prod_cod
> e'.product#c.tavg_poly_`k'"
 37.                     }
 38.                     else if "`slot'" == "lr" {
 39.                         if `a' == 1 local delta_nm "`a'b.agegroup#`prod_co
> de'.product#c.tavg_poly_`k'#c.lr_tavg_adm1_avg"
 40.                         else        local delta_nm "`a'.agegroup#`prod_cod
> e'.product#c.tavg_poly_`k'#c.lr_tavg_adm1_avg"
 41.                     }
 42.                     else {
 43.                         if `a' == 1 local delta_nm "`a'b.agegroup#`prod_co
> de'.product#c.tavg_poly_`k'#c.loggdppc_adm1_avg"
 44.                         else        local delta_nm "`a'.agegroup#`prod_cod
> e'.product#c.tavg_poly_`k'#c.loggdppc_adm1_avg"
 45.                     }
 46.                 }
 47. 
.                 local ib = colnumb(B, "`base_nm'")
 48.                 if `ib' == 0 di as err "!! base coef not found: `base_nm'"
 49. 
.                 if `has_delta' {
 50.                     local id = colnumb(B, "`delta_nm'")
 51.                     if `id' == 0 di as err "!! delta coef not found: `delt
> a_nm'"
 52.                     matrix GAMMA[1,`idx'] = el(B,1,`ib') + el(B,1,`id')
 53.                 }
 54.                 else {
 55.                     matrix GAMMA[1,`idx'] = el(B,1,`ib')
 56.                 }
 57. 
.                 local base_idx_`idx'  = `ib'
 58.                 local delta_idx_`idx' = `id'
 59.                 local has_delta_`idx' = `has_delta'
 60. 
.             }
 61.         }
 62.     }
 63. 
.     forvalues r = 1/`ncoef' {
 64.         forvalues c = 1/`ncoef' {
 65.             local ib_r = `base_idx_`r''
 66.             local ib_c = `base_idx_`c''
 67.             local id_r = `delta_idx_`r''
 68.             local id_c = `delta_idx_`c''
 69.             local hd_r = `has_delta_`r''
 70.             local hd_c = `has_delta_`c''
 71. 
.             local vcv_val = el(V, `ib_r', `ib_c')
 72.             if `hd_r' & `hd_c'  local vcv_val = `vcv_val' + el(V,`id_r',`i
> d_c') + el(V,`ib_r',`id_c') + el(V,`id_r',`ib_c')
 73.             else if `hd_r'      local vcv_val = `vcv_val' + el(V,`id_r',`i
> b_c')
 74.             else if `hd_c'      local vcv_val = `vcv_val' + el(V,`ib_r',`i
> d_c')
 75.             matrix GVCV[`r',`c'] = `vcv_val'
 76.         }
 77.     }
 78. 
.     local CSVVFILE "agespec_interaction_response_spec2_`prod_name'_prodint.cs
> vv"
 79.     cap file close csvv
 80.     file open csvv using "`CSVVDIR'/`CSVVFILE'", write replace
 81. 
.     file write csvv "---" _n
 82.     file write csvv "oneline: Age-specific interacted (Spec 2) ALLREA 1deg
>  response – `prod_name'" _n
 83.     file write csvv "version: MORTALITY-AGE-SPEC-ALLREA-1DEG-`prod_name'" 
> _n
 84.     file write csvv "dependencies: agespec_prod_interact_spec2_ALLREA.ster
> " _n
 85.     file write csvv "description: 4th-order poly OLS pooled ALLREA 1deg; a
> ge×product interactions; per-product coefficients reconstructed from base+del
> ta" _n
 86.     file write csvv "csvv-version: auto-`c(current_date)'" _n
 87. 
.     file write csvv "variables:" _n
 88.     file write csvv "  tavg_poly_1: T1_sum [C]" _n
 89.     file write csvv "  tavg_poly_2: T2_sum [C^2]" _n
 90.     file write csvv "  tavg_poly_3: T3_sum [C^3]" _n
 91.     file write csvv "  tavg_poly_4: T4_sum [C^4]" _n
 92.     file write csvv "  lr_tavg: long-run mean annual temperature [C]" _n
 93.     file write csvv "  loggdppc_adm1_avg: log GDP per capita" _n
 94.     file write csvv "  deathrate_w99: mortality rate winsorized at 99th pe
> rcentile" _n
 95.     file write csvv "..." _n
 96. 
.     file write csvv "observations" _n
 97.     file write csvv "`=e(N)'" _n
 98. 
.     file write csvv "prednames" _n
 99.     file write csvv "tavg_poly_1, tavg_poly_2, tavg_poly_3, tavg_poly_4" _
> n
100. 
.     file write csvv "covarnames" _n
101.     file write csvv "1, lr_tavg, loggdppc_adm1_avg" _n
102. 
.     file write csvv "gamma" _n
103.     forvalues i = 1/`ncoef' {
104.         file write csvv "`=el(GAMMA,1,`i')'"
105.         if mod(`i',3) != 0 file write csvv ", "
106.         else               file write csvv "" _n
107.     }
108. 
.     file write csvv "gammavcv" _n
109.     forvalues r = 1/`ncoef' {
110.         forvalues c = 1/`ncoef' {
111.             if `c'==1 file write csvv "`=el(GVCV,`r',`c')'"
112.             else      file write csvv ", `=el(GVCV,`r',`c')'"
113.         }
114.         file write csvv "" _n
115.     }
116. 
.     file write csvv "residvcv" _n
117.     file write csvv "`=e(rmse)^2'" _n
118. 
.     file close csvv
119.     di as res " Wrote `CSVVFILE'"
120. }

============================================================
Building CSVV for product: ERA5_025 (code=1)
============================================================
 Wrote agespec_interaction_response_spec2_ERA5_025_prodint.csvv

============================================================
Building CSVV for product: GMFD (code=2)
============================================================
 Wrote agespec_interaction_response_spec2_GMFD_prodint.csvv

============================================================
Building CSVV for product: JRA_3Q (code=3)
============================================================
 Wrote agespec_interaction_response_spec2_JRA_3Q_prodint.csvv

============================================================
Building CSVV for product: MERRA2 (code=4)
============================================================
 Wrote agespec_interaction_response_spec2_MERRA2_prodint.csvv

. 
. di ""


. di as res "All 4 per-product CSVVs written to `CSVVDIR'"
All 4 per-product CSVVs written to /user/ab5405/summeraliaclimate/code/mortalit
> y_pipeline/output/1deg/age_spec_interacted_csvv

. 
end of do-file
