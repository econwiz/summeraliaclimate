. * helper program: load ster, dump e(b) to CSV
. capture program drop est_to_csv

. program define est_to_csv
  1.     syntax using/, SAVE(string)
  2. 
.     estimates clear        // <-- this clears estimation results safely
  3.     estimates use "`using'"   // <-- no "clear" allowed here
  4. 
.     matrix b = e(b)
  5.     local k = colsof(b)
  6.     local names : colnames b
  7. 
.     preserve
  8.         clear
  9.         set obs `k'
 10.         gen strL parm = ""
 11.         gen double beta = .
 12. 
.         local j = 1
 13.         foreach nm of local names {
 14.             replace parm = "`nm'"   in `j'
 15.             replace beta = b[1,`j'] in `j'
 16.             local ++j
 17.         }
 18. 
.         order parm beta
 19.         export delimited using "`save'", replace
 20.     restore
 21. end

. 
. 
