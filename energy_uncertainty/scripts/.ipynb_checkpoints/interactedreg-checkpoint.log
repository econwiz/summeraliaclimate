. do interactedreg.do 

. ************************************************************
. * 3_FD_interacted_all.do
. * Replicate CIL stacked "interacted" FD spec for all products,
. * dropping TINV HDD/CDD terms, and export coeff/vcov.
. ************************************************************
. clear all

. set more off

. 
. global PROJECT "/user/ab5405/summeraliaclimate/code/energy_uncertainty"

. global DATA    "$PROJECT/data"

. global REGD    "$DATA/regression"

. global OUTDIR  "$DATA/regression/sters"

. cap mkdir "$OUTDIR"

. 
. * Choose model / submodel names as you like;
. * these only really affect ster FILE naming (not est names).
. local model    "TINV_clim"

. local submodel "lininter"   // or "quadinter" or "" as needed

. 
. if "`submodel'" != "" local model_name = "`model'_`submodel'"

. else local model_name = "`model'"

. 
. local products "GMFD ERA5 JRA_3Q MERRA2"

. 
. foreach product of local products {
  2. 
.     di "==============================================="
  3.     di "  Interacted FD spec for `product' (`model_name')"
  4.     di "==============================================="
  5. 
.     * suffix only used for FILE names, NOT variable names
.     local suf = "`product'"
  6. 
.     * Load FD dataset
.     use "$REGD/`product'_TINV_clim_regsort.dta", clear
  7. 
.     * time set
.     sort region_i year
  8.     tset region_i year
  9. 
.     * -------- long run income x income group (FD_I*lgdppc_MA15) ----------
.     local lgdppc_MA15_r ""
 10.     forval pg = 1/2 {
 11.         forval lg = 1/2 {
 12.             local lgdppc_MA15_r = ///
>                 "`lgdppc_MA15_r' c.indp`pg'#c.indf1#c.FD_I`lg'lgdppc_MA15"
 13.         }
 14.     }
 15. 
.     * -------- large income group dummies ----------
.     forval pg = 1/2 {
 16.         forval lg = 1/2 {
 17.             gen DumIncG`lg'F1P`pg' = FD_largeind`lg' * indf1 * indp`pg'
 18.         }
 19.     }
 20. 
.     * -------- precip: indp × indf1 × FD_precipk (NO product suffix) --------
> --
.     local precip_r ""
 21.     forval pg = 1/2 {
 22.         forval k  = 1/2 {
 23.             local precip_r = ///
>                 "`precip_r' c.indp`pg'#c.indf1#c.FD_precip`k'"
 24.         }
 25.     }
 26. 
.     * -------- temp: indp × indf1 × FD_tempk (NO product suffix) ----------
.     local temp_r ""
 27.     forval pg = 1/2 {
 28.         forval k  = 1/2 {   // interacted spec uses k=1/2
 29.             local temp_r = ///
>                 "`temp_r' c.indp`pg'#c.indf1#c.FD_temp`k'"
 30.         }
 31.     }
 32. 
.     * -------- temp x long-run climate (TINV HDD/CDD) ----------
.     * You decided NOT to use these, so leave empty.
.     local climate_r ""
 33. 
.     * -------- temp x income spline (FD_dc1_lgdppc_MA15I`lg'temp`k') --------
> --
.     * These exist without product suffix: FD_dc1_lgdppc_MA15I1temp1, ...
.     local income_spline_r ""
 34.     forval pg = 1/2 {
 35.         forval lg = 1/2 {
 36.             forval k  = 1/2 {
 37.                 local income_spline_r = ///
>                     "`income_spline_r' c.indp`pg'#c.indf1#c.FD_dc1_lgdppc_MA1
> 5I`lg'temp`k'"
 38.             }
 39.         }
 40.     }
 41. 
.     * -------- temp x year (optional, for lininter / quadinter) ----------
.     local year_temp_r ""
 42.     if ("`submodel'" == "lininter" | "`submodel'" == "quadinter") {
 43.         forval pg = 1/2 {
 44.             forval k  = 1/2 {
 45.                 * Your FD builder created FD_yeartemp1, FD_yeartemp2 (no s
> uffix)
.                 local year_temp_r = ///
>                     "`year_temp_r' c.indp`pg'#c.indf1#c.FD_yeartemp`k'"
 46.             }
 47.         }
 48.     }
 49. 
.     * -------- temp x year x income spline ----------
.     local year_income_spline_r ""
 50.     if ("`submodel'" == "lininter" | "`submodel'" == "quadinter") {
 51.         forval pg = 1/2 {
 52.             forval lg = 1/2 {
 53.                 forval k  = 1/2 {
 54.                     local year_income_spline_r = ///
>                         "`year_income_spline_r' c.indp`pg'#c.indf1#c.FD_dc1_l
> gdppc_MA15yearI`lg'temp`k'"
 55.                 }
 56.             }
 57.         }
 58.     }
 59. 
.     * -------- temp x year^2 parts if quadinter ----------
.     if ("`submodel'" == "quadinter") {
 60. 
.         * add year^2 × temp: FD_year2temp`k'
.         forval pg = 1/2 {
 61.             forval k  = 1/2 {
 62.                 local year_temp_r = ///
>                     "`year_temp_r' c.indp`pg'#c.indf1#c.FD_year2temp`k'"
 63.             }
 64.         }
 65. 
.         * add year^2 × temp × income spline
.         forval pg = 1/2 {
 66.             forval lg = 1/2 {
 67.                 forval k  = 1/2 {
 68.                     local year_income_spline_r = ///
>                         "`year_income_spline_r' c.indp`pg'#c.indf1#c.FD_dc1_l
> gdppc_MA15year2I`lg'temp`k'"
 69.                 }
 70.             }
 71.         }
 72.     }
 73. 
.     * ------------------------------------------------------
.     * First-stage interacted regression
.     * ------------------------------------------------------
.     reghdfe FD_load_pc ///
>         `temp_r' `precip_r' `climate_r' ///
>         `lgdppc_MA15_r' `income_spline_r' ///
>         `year_temp_r' `year_income_spline_r' ///
>         DumInc*, absorb(i.flow_i#i.product_i#i.year#i.subregionid) ///
>         cluster(region_i) residuals(resid)
 74. 
.     * Use SHORT estimation name so Stata is happy
.     estimates store FDint_`product'
 75.     estimates save "$OUTDIR/FD_inter_`model_name'_`product'", replace
 76. 
.     * ------------------------------------------------------
.     * FGLS weights (omega-by-region_i)
.     * ------------------------------------------------------
.     drop if resid == .
 77. 
.     bysort region_i: egen sd_resid = sd(resid)
 78.     gen omega = sd_resid^2
 79.     drop sd_resid
 80. 
.     gen weight = 1/omega
 81.     drop resid
 82. 
.     * ------------------------------------------------------
.     * Second-stage FGLS interacted regression
.     * ------------------------------------------------------
.     reghdfe FD_load_pc ///
>         `temp_r' `precip_r' `climate_r' ///
>         `lgdppc_MA15_r' `income_spline_r' ///
>         `year_temp_r' `year_income_spline_r' ///
>         DumInc* [pw = weight], ///
>         absorb(i.flow_i#i.product_i#i.year#i.subregionid) ///
>         cluster(region_i)
 83. 
.     estimates store FDintF_`product'
 84.     estimates save "$OUTDIR/FD_FGLS_inter_`model_name'_`product'", replace
 85. 
.     * ------------------------------------------------------
.     * Export coeffs and vcov for this PRODUCT (long format)
.     * ------------------------------------------------------
. 
.     * 1) Coefficient vector: parm, beta
.     matrix b = e(b)
 86.     local k = colsof(b)
 87.     local names : colnames b
 88. 
.     preserve
 89.         clear
 90.         set obs `k'
 91.         gen strL parm = ""
 92.         gen double beta = .
 93. 
.         local j = 1
 94.         foreach nm of local names {
 95.             replace parm = "`nm'" in `j'
 96.             replace beta = b[1,`j'] in `j'
 97.             local ++j
 98.         }
 99. 
.         order parm beta
100.         export delimited using ///
>             "$OUTDIR/FD_FGLS_inter_`model_name'_`product'_coeff.csv", replace
101.     restore
102. 
.     * 2) Variance–covariance matrix: parm_i, parm_j, v
.     matrix V = e(V)
103.     local k = rowsof(V)
104.     local names : rownames V
105. 
.     preserve
106.         clear
107.         * We’ll create k^2 rows: one per (i,j) pair
.         set obs `=`k'*`k''
108. 
.         gen int i = .
109.         gen int j = .
110.         gen strL parm_i = ""
111.         gen strL parm_j = ""
112.         gen double v = .
113. 
.         local r = 1
114.         forvalues ii = 1/`k' {
115.             forvalues jj = 1/`k' {
116.                 replace i = `ii' in `r'
117.                 replace j = `jj' in `r'
118. 
.                 local name_i : word `ii' of `names'
119.                 local name_j : word `jj' of `names'
120.                 replace parm_i = "`name_i'" in `r'
121.                 replace parm_j = "`name_j'" in `r'
122. 
.                 replace v = V[`ii',`jj'] in `r'
123. 
.                 local ++r
124.             }
125.         }
126. 
.         drop i j
127.         order parm_i parm_j v
128.         export delimited using ///
>             "$OUTDIR/FD_FGLS_inter_`model_name'_`product'_vcov_long.csv", rep
> lace
129.     restore
130. 
. }
