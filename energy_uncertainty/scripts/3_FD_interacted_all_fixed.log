. do 3_FD_interacted_all_fixed.do 

. /************************************************************ * 3_FD_interact
> ed_all.do * Replicate CIL stacked "interacted" FD spec for all products * usi
> ng UNSUFFIXED regressors (no _GMFD/_ERA5 in variable names). * * Saves: * $OU
> TDIR/FD_inter_`model_name'_`product'.ster * $OUTDIR/FD_FGLS_inter_`model_name
> '_`product'.ster * * Optional: * complete_for_plot = 1 reposts e(b), e(V) to 
> include omitted terms as 0 * so predictnl/_b[...] works even if terms were co
> llinear/omitted. ************************************************************
> / 
. clear all 

. set more off 

. 
. global PROJECT "/user/ab5405/summeraliaclimate/code/energy_uncertainty" 

. global DATA "$PROJECT/data" 

. global REGD "$DATA/regression" 

. global OUTDIR "$DATA/regression/sters" 

. cap mkdir "$OUTDIR" 

. 
. * naming only 
. local model "TINV_clim" 

. local submodel "quadinter" // "" | "lininter" | "quadinter" 

. 
. if "`submodel'" != "" local model_name "`model'_`submodel'" 

. else local model_name "`model'" 

. 
. local products "GMFD ERA5 JRA_3Q MERRA2" 

. 
. * 1 = make saved .ster plotting-safe (include omitted terms as 0) 
. * 0 = save Stata default e(b), e(V) 
. local complete_for_plot 0 

. 
. foreach product of local products { 
  2.         di "===============================================" 
  3.         di " Interacted FD spec for `product' (`model_name')" 
  4.         di "===============================================" 
  5. 
.         * Load FD dataset 
.         use "$REGD/`product'_TINV_clim_regsort.dta", clear 
  6. 
.         * time set 
.         sort region_i year 
  7.         tset region_i year 
  8. 
.         * -------- long run income x income group ---------- 
.         local lgdppc_MA15_r "" 
  9.         forval pg = 1/2 { 
 10.                 forval lg = 1/2 { 
 11.                         local lgdppc_MA15_r /// 
>                                 "`lgdppc_MA15_r' c.indp`pg'#c.indf1#c.FD_I`lg
> 'lgdppc_MA15" 
 12.                 } 
 13.         } 
 14. 
.         * -------- large income group dummies ---------- 
.         forval pg = 1/2 { 
 15.                 forval lg = 1/2 { 
 16.                         gen DumIncG`lg'F1P`pg' = FD_largeind`lg' * indf1 *
>  indp`pg' 
 17.                 } 
 18.         } 
 19. 
.         * -------- precip: indp × indf1 × FD_precipk (UNSUFFIXED) ---------- 
.         local precip_r "" 
 20.         forval pg = 1/2 { 
 21.                 forval k = 1/2 { 
 22.                         local precip_r /// 
>                                 "`precip_r' c.indp`pg'#c.indf1#c.FD_precip`k'
> " 
 23.                 } 
 24.         } 
 25. 
.         * -------- temp: indp × indf1 × FD_tempk (UNSUFFIXED) ---------- 
.         local temp_r "" 
 26.         forval pg = 1/2 { 
 27.                 forval k = 1/2 { 
 28.                         local temp_r /// 
>                                 "`temp_r' c.indp`pg'#c.indf1#c.FD_temp`k'" 
 29.                 } 
 30.         } 
 31. 
.         * -------- temp x long-run climate (MATCH CIL construction: redundant
>  lg loop) ---------- 
.         local climate_r "" 
 32.         forval pg = 1/2 { 
 33.                 forval lg = 1/2 { 
 34.                         forval k = 1/2 { 
 35.                                 local climate_r "`climate_r' c.indp`pg'#c.
> indf1#c.FD_hdd20_TINVtemp`k'" 
 36.                                 local climate_r "`climate_r' c.indp`pg'#c.
> indf1#c.FD_cdd20_TINVtemp`k'" 
 37.                         } 
 38.                 } 
 39.         } 
 40. 
.         * -------- temp x income spline (UNSUFFIXED) ---------- 
.         local income_spline_r "" 
 41.         forval pg = 1/2 { 
 42.                 forval lg = 1/2 { 
 43.                         forval k = 1/2 { 
 44.                                 local income_spline_r /// 
>                                         "`income_spline_r' c.indp`pg'#c.indf1
> #c.FD_dc1_lgdppc_MA15I`lg'temp`k'" 
 45.                         } 
 46.                 } 
 47.         } 
 48. 
.         * -------- temp x year (for lininter/quadinter) ---------- 
.         local year_temp_r "" 
 49.         local year_income_spline_r "" 
 50. 
.         if ("`submodel'" == "lininter" | "`submodel'" == "quadinter") { 
 51.                 forval pg = 1/2 { 
 52.                         forval k = 1/2 { 
 53.                                 local year_temp_r /// 
>                                         "`year_temp_r' c.indp`pg'#c.indf1#c.F
> D_yeartemp`k'" 
 54.                         } 
 55.                 } 
 56. 
.                 forval pg = 1/2 { 
 57.                         forval lg = 1/2 { 
 58.                                 forval k = 1/2 { 
 59.                                         local year_income_spline_r /// 
>                                                 "`year_income_spline_r' c.ind
> p`pg'#c.indf1#c.FD_dc1_lgdppc_MA15yearI`lg'temp`k'" 
 60.                                 } 
 61.                         } 
 62.                 } 
 63.         } 
 64. 
.         * -------- temp x year^2 (for quadinter) ---------- 
.         if ("`submodel'" == "quadinter") { 
 65.                 forval pg = 1/2 { 
 66.                         forval k = 1/2 { 
 67.                                 local year_temp_r /// 
>                                         "`year_temp_r' c.indp`pg'#c.indf1#c.F
> D_year2temp`k'" 
 68.                         } 
 69.                 } 
 70. 
.                 forval pg = 1/2 { 
 71.                         forval lg = 1/2 { 
 72.                                 forval k = 1/2 { 
 73.                                         local year_income_spline_r /// 
>                                                 "`year_income_spline_r' c.ind
> p`pg'#c.indf1#c.FD_dc1_lgdppc_MA15year2I`lg'temp`k'" 
 74.                                 } 
 75.                         } 
 76.                 } 
 77.         } 
 78. 
.         * ------------------------------------------------------ 
.         * Pop weights (MATCH CIL) 
.         * ------------------------------------------------------ 
.         bysort year product flow: egen year_product_flow_total_pop = total(po
> p) 
 79.         gen double pop_weight = pop / year_product_flow_total_pop 
 80. 
.         * ------------------------------------------------------ 
.         * First-stage (MATCH CIL: pop weights) + residuals for FGLS 
.         * ------------------------------------------------------ 
.         capture drop resid 
 81.         reghdfe FD_load_pc /// 
>                 `temp_r' `precip_r' `climate_r' /// 
>                 `lgdppc_MA15_r' `income_spline_r' /// 
>                 `year_temp_r' `year_income_spline_r' /// 
>                 DumInc* [pw=pop_weight], /// 
>                 absorb(i.flow_i#i.product_i#i.year#i.subregionid) /// 
>                 vce(cluster region_i) residuals(resid) 
 82. 
.         estimates save "$OUTDIR/FD_inter_`model_name'_`product'", replace 
 83. 
.         * ------------------------------------------------------ 
.         * FGLS weights (MATCH CIL exactly) 
.         * ------------------------------------------------------ 
.         drop if missing(resid) 
 84.         bysort region_i: gen count = _N 
 85.         bysort region_i: egen sum_of_weights_in_FE = total(pop_weight) 
 86.         gen double for_variance_weighting = pop_weight / sum_of_weights_in
> _FE 
 87.         gen double weighted_residual = for_variance_weighting * resid 
 88.         bysort region_i: egen weighted_mean_resid_FE_level = mean(weighted
> _residual) 
 89.         gen double square_term_weighted = for_variance_weighting * (resid 
> - weighted_mean_resid_FE_level)^2 
 90.         bysort region_i: egen weighted_residual_variance = total(square_te
> rm_weighted) 
 91.         gen double FGLS_weight = pop_weight / weighted_residual_variance 
 92.         drop if count == 1 // singleton FE like CIL 
 93. 
.         * ------------------------------------------------------ 
.         * Second-stage (MATCH CIL: FGLS weights) 
.         * ------------------------------------------------------ 
.         reghdfe FD_load_pc /// 
>                 `temp_r' `precip_r' `climate_r' /// 
>                 `lgdppc_MA15_r' `income_spline_r' /// 
>                 `year_temp_r' `year_income_spline_r' /// 
>                 DumInc* [pw=FGLS_weight], /// 
>                 absorb(i.flow_i#i.product_i#i.year#i.subregionid) /// 
>                 vce(cluster region_i) 
 94. 
.         * ------------------------------------------------------ 
.         * Optional: make .ster safe for predictnl/_b[...] (omitted -> 0) 
.         * ------------------------------------------------------ 
.         if (`complete_for_plot') { 
 95.                 local want_all "" 
 96.                 local want_all "`want_all' `temp_r' `precip_r' `climate_r'
> " 
 97.                 local want_all "`want_all' `lgdppc_MA15_r' `income_spline_
> r'" 
 98.                 local want_all "`want_all' `year_temp_r' `year_income_spli
> ne_r'" 
 99.                 unab dumlist : DumInc* 
100.                 local want_all "`want_all' `dumlist'" 
101. 
.                 local want "" 
102.                 foreach nm of local want_all { 
103.                         if strpos(" `want' ", " `nm' ") == 0 local want "`
> want' `nm'" 
104.                 } 
105. 
.                 local K_want : word count `want' 
106.                 tempname b V bfull Vfull 
107.                 matrix `b' = e(b) 
108.                 matrix `V' = e(V) 
109. 
.                 matrix `bfull' = J(1, `K_want', 0) 
110.                 matrix colnames `bfull' = `want' 
111.                 matrix `Vfull' = J(`K_want', `K_want', 0) 
112.                 matrix rownames `Vfull' = `want' 
113.                 matrix colnames `Vfull' = `want' 
114. 
.                 local i = 0 
115.                 foreach ni of local want { 
116.                         local ++i 
117.                         local ci = colnumb(`b', "`ni'") 
118.                         if (`ci' < .) matrix `bfull'[1,`i'] = `b'[1,`ci'] 
119. 
.                         local ri = rownumb(`V', "`ni'") 
120.                         if (`ri' < .) { 
121.                                 local j = 0 
122.                                 foreach nj of local want { 
123.                                         local ++j 
124.                                         local cj = colnumb(`V', "`nj'") 
125.                                         if (`cj' < .) matrix `Vfull'[`i',`
> j'] = `V'[`ri',`cj'] 
126.                                 } 
127.                         } 
128.                 } 
129. 
.                 ereturn repost b=`bfull' V=`Vfull', rename 
130.         } 
131. 
.         estimates save "$OUTDIR/FD_FGLS_inter_`model_name'_`product'", replac
> e 
132. 
.         * ------------------------------------------------------ 
.         * Export coeff vector (parm, beta) 
.         * ------------------------------------------------------ 
.         matrix b = e(b) 
133.         local kb = colsof(b) 
134.         local bnames : colnames b 
135. 
.         preserve 
136.         clear 
137.         set obs `kb' 
138.         gen strL parm = "" 
139.         gen double beta = . 
140. 
.         local j = 1 
141.         foreach nm of local bnames { 
142.                 replace parm = "`nm'" in `j' 
143.                 replace beta = b[1,`j'] in `j' 
144.                 local ++j 
145.         } 
146. 
.         order parm beta 
147.         export delimited using /// 
>                 "$OUTDIR/FD_FGLS_inter_`model_name'_`product'_coeff.csv", rep
> lace 
148.         restore 
149. 
.         * ------------------------------------------------------ 
.         * Export vcov matrix (long format: parm_i, parm_j, v) 
.         * ------------------------------------------------------ 
.         matrix V = e(V) 
150.         local kv = rowsof(V) 
151.         local vnames : rownames V 
152. 
.         preserve 
153.         clear 
154.         set obs `=`kv'*`kv'' 
155.         gen strL parm_i = "" 
156.         gen strL parm_j = "" 
157.         gen double v = . 
158. 
.         local r = 1 
159.         forvalues ii = 1/`kv' { 
160.                 forvalues jj = 1/`kv' { 
161.                         local name_i : word `ii' of `vnames' 
162.                         local name_j : word `jj' of `vnames' 
163.                         replace parm_i = "`name_i'" in `r' 
164.                         replace parm_j = "`name_j'" in `r' 
165.                         replace v = V[`ii',`jj'] in `r' 
166.                         local ++r 
167.                 } 
168.         } 
169. 
.         order parm_i parm_j v 
170.         export delimited using /// 
>                 "$OUTDIR/FD_FGLS_inter_`model_name'_`product'_vcov_long.csv",
>  replace 
171.         restore 
172. 
.         di "" 
173.         di "Exported coefficient and vcov CSVs for `product'" 
174.         di "" 
175. 
. } 
