. do plotsimp.do 

. /*
> Working version - treat missing/omitted coefficients as zero
> */
. 
. set scheme s1color

. clear all

. set more off

. 
. global PROJECT "/user/ab5405/summeraliaclimate/code/energy_uncertainty"

. global EDR "/user/ab5405/summeraliaclimate/code/energy_consumption/energy_dat
> a_release_2021oct21/DATA/regression"

. global DATA    "$PROJECT/data"

. global STERD   "$DATA/regression/sters"

. global OUTPUT  "$PROJECT/figures"

. 
. cap mkdir "$OUTPUT"

. 
. local model_name "TINV_clim_quadinter"

. local fuels "electricity other_energy"

. local products "GMFD ERA5 JRA_3Q MERRA2"

. local year 2099

. 
. local col_electricity "dknavy"

. local col_other_energy "dkorange"

. 
. * Precompute tercile means
. tempfile tpid_means tgpid_means

. preserve

.     use "$EDR/break_data_TINV_clim.dta", clear

.     collapse (mean) avgCDD_tpid avgHDD_tpid, by(tpid)

.     save `tpid_means'
file /tmp/St52379.000001 saved as .dta format

. restore

. 
. preserve

.     use "$EDR/break_data_TINV_clim.dta", clear  

.     collapse (mean) avgInc_tgpid, by(tgpid)

.     save `tgpid_means'
file /tmp/St52379.000002 saved as .dta format

. restore

. 
. foreach product of local products {
  2.     foreach var of local fuels {
  3. 
.         di ""
  4.         di "================================================"
  5.         di "`product' - `var'"
  6.         di "================================================"
  7. 
.         * pg assignment
.         local pg = cond("`var'"=="electricity", 1, 2)
  8. 
.         * Get income knot
.         preserve
  9.             use "$EDR/break_data_TINV_clim.dta", clear
 10.             qui summ maxInc_largegpid_`var' if largegpid_`var' == 1
 11.             local ibar = r(max)
 12.         restore
 13. 
.         * Load estimates
.         estimates use "$STERD/FD_FGLS_inter_`model_name'_`product'"
 14.         
.         * Get all coefficient names
.         matrix b = e(b)
 15.         local allnames : colnames b
 16. 
.         * Create temp grid
.         clear
 17.         set obs 41
 18.         gen double temp1 = _n - 6
 19.         gen double temp2 = temp1^2
 20.         gen byte above20 = (temp1 >= 20)
 21.         gen byte below20 = (temp1 < 20)
 22. 
.         local col_main "`col_`var''"
 23.         local graphicM ""
 24. 
.         forval lg=3(-1)1 {
 25.             forval tr=3(-1)1 {
 26. 
.                 local cellid = `lg' + `tr'*100
 27. 
.                 * Get cell values from precomputed means
.                 preserve
 28.                     use `tpid_means', clear
 29.                     qui su avgCDD_tpid if tpid==`tr'
 30.                     local subCDD = r(mean)
 31.                     qui su avgHDD_tpid if tpid==`tr'
 32.                     local subHDD = r(mean)
 33.                 restore
 34.                 
.                 preserve
 35.                     use `tgpid_means', clear
 36.                     qui su avgInc_tgpid if tgpid==`lg'
 37.                     local subInc = r(mean)
 38.                 restore
 39. 
.                 local deltacut = `subInc' - `ibar'
 40.                 local ig = cond(`subInc' > `ibar', 2, 1)
 41. 
.                 * Build expression - only use coefficients that EXIST
.                 local line "0"
 42.                 
.                 foreach k of num 1/2 {
 43.                     * Base temp (always exists)
.                     local line "`line' + _b[c.indp`pg'#c.indf1#c.FD_temp`k']*
> (temp`k'-20^`k')"
 44.                     
.                     * Climate
.                     local line "`line' + above20*_b[c.indp`pg'#c.indf1#c.FD_c
> dd20_TINVtemp`k']*`subCDD'*(temp`k'-20^`k')"
 45.                     local line "`line' + below20*_b[c.indp`pg'#c.indf1#c.F
> D_hdd20_TINVtemp`k']*`subHDD'*(20^`k'-temp`k')"
 46.                     
.                     * Income spline
.                     local line "`line' + _b[c.indp`pg'#c.indf1#c.FD_dc1_lgdpp
> c_MA15I`ig'temp`k']*`deltacut'*(temp`k'-20^`k')"
 47.                     
.                     * Year terms - check if they exist (not omitted)
.                     local yt "c.indp`pg'#c.indf1#c.FD_yeartemp`k'"
 48.                     local found 0
 49.                     foreach nm of local allnames {
 50.                         if "`nm'"=="`yt'" local found 1
 51.                     }
 52.                     if `found' {
 53.                         local line "`line' + _b[`yt']*(temp`k'-20^`k')*`ye
> ar'"
 54.                     }
 55.                     
.                     * Year x income
.                     local yinc "c.indp`pg'#c.indf1#c.FD_dc1_lgdppc_MA15yearI`
> ig'temp`k'"
 56.                     local found 0
 57.                     foreach nm of local allnames {
 58.                         if "`nm'"=="`yinc'" local found 1
 59.                     }
 60.                     if `found' {
 61.                         local line "`line' + _b[`yinc']*`deltacut'*`year'*
> (temp`k'-20^`k')"
 62.                     }
 63.                     
.                     * Year²
.                     local y2t "c.indp`pg'#c.indf1#c.FD_year2temp`k'"
 64.                     local found 0
 65.                     foreach nm of local allnames {
 66.                         if "`nm'"=="`y2t'" local found 1
 67.                     }
 68.                     if `found' {
 69.                         local line "`line' + _b[`y2t']*(temp`k'-20^`k')*`y
> ear'^2"
 70.                     }
 71.                     
.                     * Year² x income
.                     local y2inc "c.indp`pg'#c.indf1#c.FD_dc1_lgdppc_MA15year2
> I`ig'temp`k'"
 72.                     local found 0
 73.                     foreach nm of local allnames {
 74.                         if "`nm'"=="`y2inc'" local found 1
 75.                     }
 76.                     if `found' {
 77.                         local line "`line' + _b[`y2inc']*`deltacut'*`year'
> ^2*(temp`k'-20^`k')"
 78.                     }
 79.                 }
 80. 
.                 * Predict
.                 cap predictnl yhat`cellid' = `line', se(se`cellid') ci(lo`cel
> lid' hi`cellid')
 81.                 
.                 if _rc {
 82.                     di as error "  Error in cell `cellid', rc=`=_rc'"
 83.                     continue, break
 84.                 }
 85. 
.                 * Plot
.                 tw ///
>                     rarea hi`cellid' lo`cellid' temp1, col(`col_main'%30) || 
> ///
>                     line yhat`cellid' temp1, lc(`col_main') lw(medthick) || /
> //
>                     , yline(0, lwidth(vthin) lc(black) lp(dash)) ///
>                     xline(20, lwidth(vthin) lc(gray) lp(dot)) ///
>                     xlabel(-5(10)35, labsize(vsmall)) ///
>                     ylabel(, labsize(vsmall) nogrid) ///
>                     legend(off) xtitle("") ytitle("") ///
>                     plotregion(color(white)) graphregion(color(white)) ///
>                     nodraw name(M`cellid', replace)
 86. 
.                 local graphicM "`graphicM' M`cellid'"
 87.             }
 88.         }
 89. 
.         * Combine
.         graph combine `graphicM', imargin(zero) ycommon rows(3) ///
>             title("`product': `var'", size(medsmall)) ///
>             subtitle("`model_name' | Year=`year'", size(vsmall)) ///
>             note("Rows: High→Mid→Low income | Cols: Hot→Mid→Cold climate", si
> ze(vsmall)) ///
>             plotregion(color(white)) graphregion(color(white))
 90. 
.         graph export "$OUTPUT/fig_3x3_`var'_`model_name'_`product'.pdf", repl
> ace
 91.         di "  ✓ Saved: fig_3x3_`var'_`model_name'_`product'.pdf"
 92. 
.         graph drop _all
 93.     }
 94. }

