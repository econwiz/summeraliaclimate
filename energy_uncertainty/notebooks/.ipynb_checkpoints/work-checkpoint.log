. do work.do 

. /*
> Purpose: 3x3 arrays - WORKING VERSION
> */
. 
. set scheme s1color

. clear all

. set more off

. 
. global PROJECT "/user/ab5405/summeraliaclimate/code/energy_uncertainty"

. global EDR "/user/ab5405/summeraliaclimate/code/energy_consumption/energy_dat
> a_release_2021oct21/DATA/regression"

. 
. global DATA    "$PROJECT/data"

. global OUTPUT  "$PROJECT"

. global STERD   "$DATA/regression/sters"

. 
. local model_main "TINV_clim"

. local submodel   "quadinter"

. local model_name "`model_main'_`submodel'"

. 
. local fuels "electricity other_energy"

. local products "GMFD ERA5 JRA_3Q MERRA2"

. 
. local year 2099

. 
. local col_electricity "dknavy"

. local col_other_energy "dkorange"

. 
. foreach product of local products {
  2.     foreach var of local fuels {
  3. 
.         di ""
  4.         di "================================================"
  5.         di "Plotting product=`product' fuel=`var' model=`model_name'"
  6.         di "================================================"
  7. 
.         * Create temperature grid
.         clear
  8.         set obs 41
  9.         
.         gen double temp1 = _n - 6
 10.         gen double temp2 = temp1^2
 11.         gen byte above20 = (temp1 >= 20)
 12.         gen byte below20 = (temp1 < 20)
 13. 
.         * Get income knot
.         preserve
 14.             use "$EDR/break_data_TINV_clim.dta", clear
 15.             qui summ maxInc_largegpid_`var' if largegpid_`var' == 1
 16.             local ibar = `r(max)'
 17.         restore
 18. 
.         di "  ibar = `ibar'"
 19. 
.         local col_main "`col_`var''"
 20. 
.         * Load estimates ONCE before loop
.         estimates use "$STERD/FD_FGLS_inter_`model_name'_`product'.ster"
 21.         
.         * Get coefficient list
.         matrix b = e(b)
 22.         local bnames : colnames b
 23. 
.         * Create 3x3 plots
.         local graphicM ""
 24. 
.         forval lg=3(-1)1 {
 25.             forval tr=3(-1)1 {
 26. 
.                 local cellid = `lg' + `tr'*100
 27. 
.                 * Get tercile covariates
.                 preserve
 28.                     use "$EDR/break_data_TINV_clim.dta", clear
 29.                     duplicates drop tpid tgpid, force
 30.                     sort tpid tgpid
 31.                     local tr_index = `tr' * 3
 32.                     local subCDD = avgCDD_tpid[`tr_index']
 33.                     local subHDD = avgHDD_tpid[`tr_index']
 34.                     local subInc = avgInc_tgpid[`lg']
 35.                 restore
 36. 
.                 * pg assignment
.                 if "`var'"=="electricity" local pg=1
 37.                 else local pg=2
 38. 
.                 * Income group
.                 local deltacut = `subInc' - `ibar'
 39.                 if (`subInc' > `ibar') local ig=2
 40.                 else local ig=1
 41. 
.                 * Build predictnl expression cleanly
.                 local line "0"
 42.                 
.                 foreach k of num 1/2 {
 43.                     * Base temperature
.                     local line "`line' + _b[c.indp`pg'#c.indf1#c.FD_temp`k']*
> (temp`k'-20^`k')"
 44.                     
.                     * Climate heterogeneity
.                     local line "`line' + above20*_b[c.indp`pg'#c.indf1#c.FD_c
> dd20_TINVtemp`k']*`subCDD'*(temp`k'-20^`k')"
 45.                     local line "`line' + below20*_b[c.indp`pg'#c.indf1#c.F
> D_hdd20_TINVtemp`k']*`subHDD'*(20^`k'-temp`k')"
 46.                     
.                     * Income spline
.                     local line "`line' + _b[c.indp`pg'#c.indf1#c.FD_dc1_lgdpp
> c_MA15I`ig'temp`k']*`deltacut'*(temp`k'-20^`k')"
 47.                     
.                     * Check if year terms exist (not omitted)
.                     * Year × temp
.                     local year_term "c.indp`pg'#c.indf1#c.FD_yeartemp`k'"
 48.                     local year_omit "co.indp`pg'#co.indf1#co.FD_yeartemp`k
> '"
 49.                     local has_year 0
 50.                     local is_omit 0
 51.                     foreach nm of local bnames {
 52.                         if "`nm'"=="`year_term'" local has_year 1
 53.                         if "`nm'"=="`year_omit'" local is_omit 1
 54.                     }
 55.                     if `has_year' & !`is_omit' {
 56.                         local line "`line' + _b[`year_term']*(temp`k'-20^`
> k')*`year'"
 57.                     }
 58.                     
.                     * Year × income × temp
.                     local dcyr_term "c.indp`pg'#c.indf1#c.FD_dc1_lgdppc_MA15y
> earI`ig'temp`k'"
 59.                     local dcyr_omit "co.indp`pg'#co.indf1#co.FD_dc1_lgdppc
> _MA15yearI`ig'temp`k'"
 60.                     local has_dcyr 0
 61.                     local is_omit 0
 62.                     foreach nm of local bnames {
 63.                         if "`nm'"=="`dcyr_term'" local has_dcyr 1
 64.                         if "`nm'"=="`dcyr_omit'" local is_omit 1
 65.                     }
 66.                     if `has_dcyr' & !`is_omit' {
 67.                         local line "`line' + _b[`dcyr_term']*`deltacut'*`y
> ear'*(temp`k'-20^`k')"
 68.                     }
 69.                     
.                     * Year² × temp
.                     local yr2_term "c.indp`pg'#c.indf1#c.FD_year2temp`k'"
 70.                     local yr2_omit "co.indp`pg'#co.indf1#co.FD_year2temp`k
> '"
 71.                     local has_yr2 0
 72.                     local is_omit 0
 73.                     foreach nm of local bnames {
 74.                         if "`nm'"=="`yr2_term'" local has_yr2 1
 75.                         if "`nm'"=="`yr2_omit'" local is_omit 1
 76.                     }
 77.                     if `has_yr2' & !`is_omit' {
 78.                         local line "`line' + _b[`yr2_term']*(temp`k'-20^`k
> ')*`year'^2"
 79.                     }
 80.                     
.                     * Year² × income × temp
.                     local dcy2_term "c.indp`pg'#c.indf1#c.FD_dc1_lgdppc_MA15y
> ear2I`ig'temp`k'"
 81.                     local dcy2_omit "co.indp`pg'#co.indf1#co.FD_dc1_lgdppc
> _MA15year2I`ig'temp`k'"
 82.                     local has_dcy2 0
 83.                     local is_omit 0
 84.                     foreach nm of local bnames {
 85.                         if "`nm'"=="`dcy2_term'" local has_dcy2 1
 86.                         if "`nm'"=="`dcy2_omit'" local is_omit 1
 87.                     }
 88.                     if `has_dcy2' & !`is_omit' {
 89.                         local line "`line' + _b[`dcy2_term']*`deltacut'*`y
> ear'^2*(temp`k'-20^`k')"
 90.                     }
 91.                 }
 92. 
.                 * Generate predictions
.                 cap predictnl yhat`cellid' = `line', se(se`cellid') ci(lo`cel
> lid' hi`cellid')
 93.                 
.                 if _rc {
 94.                     di as error "  ERROR in cell `cellid', rc=`=_rc'"
 95.                     continue, break
 96.                 }
 97. 
.                 * Create subplot
.                 tw ///
>                     rarea hi`cellid' lo`cellid' temp1, col(`col_main'%30) || 
> ///
>                     line yhat`cellid' temp1, lc(`col_main') lw(medthick) || /
> //
>                     , yline(0, lwidth(vthin) lc(black) lp(dash)) ///
>                     xline(20, lwidth(vthin) lc(gray) lp(dot)) ///
>                     xlabel(-5(10)35, labsize(vsmall)) ///
>                     ylabel(, labsize(vsmall) nogrid format(%5.2f)) ///
>                     legend(off) ///
>                     xtitle("") ytitle("") ///
>                     plotregion(color(white)) graphregion(color(white)) ///
>                     nodraw name(Maddgraph`cellid', replace)
 98. 
.                 local graphicM "`graphicM' Maddgraph`cellid'"
 99.             }
100.         }
101. 
.         * Combine and save
.         graph combine `graphicM', imargin(zero) ycommon rows(3) ///
>             title("`product': `var'", size(medsmall)) ///
>             subtitle("`model_name' | Year=`year'", size(vsmall)) ///
>             note("Rows: High→Mid→Low income | Cols: Hot→Mid→Cold climate", si
> ze(vsmall)) ///
>             plotregion(color(white)) graphregion(color(white)) ///
>             name(comb_`product'_`var', replace)
102. 
.         cap mkdir "$OUTPUT/figures"
103.         local figname "$OUTPUT/figures/fig_3x3_`var'_`model_name'_`product
> '.pdf"
104.         graph export "`figname'", replace
105.         
.         di "  ✓ Saved: `figname'"
106.         
.         graph drop _all
107.     }
108. }

