. do figure.do 

. /*
> Purpose: 3x3 arrays energy-temperature response (income x climate)
> Loop over climate products using YOUR .ster outputs.
> UNSUFFIXED coefficients (no _GMFD on _b[] names).
> */
. 
. set scheme s1color

. clear all

. set more off

. 
. global PROJECT "/user/ab5405/summeraliaclimate/code/energy_uncertainty"

. global DATA    "$PROJECT/data"

. global OUTPUT  "$PROJECT"              // for figures output path if you want

. global STERD   "$DATA/regression/sters"

. 
. * ---- USER CONTROLS ----
. local model_main "TINV_clim"

. local submodel   "quadinter"

. local model_name "`model_main'_`submodel'"

. 
. local fuels "electricity other_energy"

. local products "GMFD ERA5 JRA_3Q MERRA2"

. 
. local year 2099

. 
. * colors (optional)
. local col_electricity "dknavy"

. local col_other_energy "dkorange"

. 
. foreach product of local products {
  2.     foreach var of local fuels {
  3. 
.         di "================================================"
  4.         di "Plotting product=`product' fuel=`var' model=`model_name'"
  5.         di "================================================"
  6. 
.         * -----------------------------
.         * Step 1: temp grid
.         * -----------------------------
.         * use any regsort just to anchor environment; then replace with empty
>  grid
.         use "$DATA/regression/`product'_`model_main'_regsort.dta", clear
  7. 
.         local obs = 35 + abs(-5) + 1
  8.         drop if _n > 0
  9.         set obs `obs'
 10. 
.         gen double temp1 = _n - 6
 11.         forval k=1/2 {
 12.             gen double temp`k' = temp1^`k'
 13.         }
 14.         gen byte above20 = (temp1 >= 20)
 15.         gen byte below20 = (temp1 < 20)
 16. 
.         * -----------------------------
.         * Step 2: knot + plotting setup
.         * -----------------------------
.         preserve
 17.             use "$DATA/regression/break_data_`model_main'.dta", clear
 18.             summ maxInc_largegpid_`var' if largegpid_`var' == 1
 19.             local ibar = `r(max)'
 20.         restore
 21. 
.         local col_main "`col_`var''"
 22. 
.         * -----------------------------
.         * Step 3: 3x3 plots
.         * -----------------------------
.         local graphicM ""
 23. 
.         forval lg=3(-1)1 {
 24.             forval tr=3(-1)1 {
 25. 
.                 local cellid = `lg' + `tr'*100
 26. 
.                 * pull tercile covariates like their code
.                 preserve
 27.                     use "$DATA/regression/break_data_`model_main'.dta", cl
> ear
 28.                     duplicates drop tpid tgpid, force
 29.                     sort tpid tgpid
 30.                     local tr_index = `tr' * 3
 31.                     local subCDD = avgCDD_tpid[`tr_index']
 32.                     local subHDD = avgHDD_tpid[`tr_index']
 33.                     local subInc = avgInc_tgpid[`lg']
 34.                 restore
 35. 
.                 * pg assignment (matches their code)
.                 if "`var'"=="electricity" local pg=1
 36.                 else local pg=2
 37. 
.                 * income group at knot
.                 local deltacut = `subInc' - `ibar'
 38.                 if (`subInc' > `ibar') local ig=2
 39.                 else local ig=1
 40. 
.                 * build predictnl expression (UNSUFFIXED)
.                 local line ""
 41.                 local add ""
 42.                 foreach k of num 1/2 {
 43. 
.                     local line = "`line' `add' _b[c.indp`pg'#c.indf1#c.FD_tem
> p`k'] * (temp`k' - 20^`k')"
 44.                     local line = "`line' + above20*_b[c.indp`pg'#c.indf1#c
> .FD_cdd20_TINVtemp`k']*`subCDD' * (temp`k' - 20^`k')"
 45.                     local line = "`line' + below20*_b[c.indp`pg'#c.indf1#c
> .FD_hdd20_TINVtemp`k']*`subHDD' * (20^`k' - temp`k')"
 46.                     local line = "`line' + _b[c.indp`pg'#c.indf1#c.FD_dc1_
> lgdppc_MA15I`ig'temp`k']*`deltacut'*(temp`k' - 20^`k')"
 47. 
.                     * lininter/quadinter pieces
.                     local line = "`line' + _b[c.indp`pg'#c.indf1#c.FD_yeartem
> p`k'] * (temp`k' - 20^`k')*`year'"
 48.                     local line = "`line' + _b[c.indp`pg'#c.indf1#c.FD_dc1_
> lgdppc_MA15yearI`ig'temp`k']*`deltacut'*`year'*(temp`k' - 20^`k')"
 49. 
.                     * quadinter only
.                     local line = "`line' + _b[c.indp`pg'#c.indf1#c.FD_year2te
> mp`k'] * (temp`k' - 20^`k')*`year'*`year'"
 50.                     local line = "`line' + _b[c.indp`pg'#c.indf1#c.FD_dc1_
> lgdppc_MA15year2I`ig'temp`k']*`deltacut'*`year'*`year'*(temp`k' - 20^`k')"
 51. 
.                     local add " + "
 52.                 }
 53. 
.                 * load your product-specific ster
.                 estimates use "$STERD/FD_FGLS_inter_`model_name'_`product'.st
> er"
 54. 
.                 * trace out curve
.                 predictnl yhat`cellid' = `line', se(se`cellid') ci(lo`cellid'
>  hi`cellid')
 55. 
.                 * subplot
.                 tw ///
>                     rarea hi`cellid' lo`cellid' temp1, col(`col_main'%30) || 
> ///
>                     line yhat`cellid' temp1, lc(`col_main') || ///
>                     yline(0, lwidth(vthin)) ///
>                     xlabel(-5(10)35, labsize(vsmall)) ///
>                     ylabel(, labsize(vsmall) nogrid) legend(off) ///
>                     plotregion(color(white)) graphregion(color(white)) nodraw
>  ///
>                     name(Maddgraph`cellid', replace)
 56. 
.                 local graphicM "`graphicM' Maddgraph`cellid'"
 57.             }
 58.         }
 59. 
.         * combine + export
.         graph combine `graphicM', imargin(zero) ycomm rows(3) ///
>             title("Split Degree Days Poly 2 Interaction Model `var' | `produc
> t'", size(small)) ///
>             subtitle("`model_name' (`col_main')", size(vsmall)) ///
>             plotregion(color(white)) graphregion(color(white)) ///
>             name(comb, replace)
 60. 
.         cap mkdir "$OUTPUT/figures"
 61.         graph export "$OUTPUT/figures/fig_3x3_`var'_interacted_`model_name
> '_`product'.pdf", replace
 62.         graph drop _all
 63.     }
 64. }
