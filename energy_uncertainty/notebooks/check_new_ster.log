. di "-------------------------------------------"
-------------------------------------------

. local count2 = 0

. foreach nm of local names {
  2.     if strpos("`nm'", "dc1_lgdppc_MA15I") > 0 & strpos("`nm'", "year") == 
> 0 {
  3.         local ++count2
  4.         di "`nm'"
  5.         if `count2' >= 10 {
  6.             di "... (showing first 10 only)"
  7.             continue, break
  8.         }
  9.     }
 10. }
c.indp1#c.indf1#c.FD_dc1_lgdppc_MA15I1temp1
c.indp1#c.indf1#c.FD_dc1_lgdppc_MA15I1temp2
c.indp1#c.indf1#c.FD_dc1_lgdppc_MA15I2temp1
c.indp1#c.indf1#c.FD_dc1_lgdppc_MA15I2temp2
c.indp2#c.indf1#c.FD_dc1_lgdppc_MA15I1temp1
c.indp2#c.indf1#c.FD_dc1_lgdppc_MA15I1temp2
c.indp2#c.indf1#c.FD_dc1_lgdppc_MA15I2temp1
c.indp2#c.indf1#c.FD_dc1_lgdppc_MA15I2temp2

. 
. di ""


. di "CHECKING EXPECTED COEFFICIENT NAMES:"
CHECKING EXPECTED COEFFICIENT NAMES:

. di "-------------------------------------------"
-------------------------------------------

. 
. * Check electricity (pg=1) temperature coefficients
. local test_names "c.indp1#c.indf1#c.FD_temp1 c.indp1#c.indf1#c.FD_temp2"

. 
. foreach tn of local test_names {
  2.     local found = 0
  3.     foreach nm of local names {
  4.         if "`nm'" == "`tn'" {
  5.             local found = 1
  6.         }
  7.     }
  8.     
.     if `found' {
  9.         di "✓ FOUND: `tn'"
 10.     }
 11.     else {
 12.         di "✗ MISSING: `tn'"
 13.     }
 14. }
✓ FOUND: c.indp1#c.indf1#c.FD_temp1
✓ FOUND: c.indp1#c.indf1#c.FD_temp2

. 
. * Check with indp2 (in case electricity uses pg=2)
. local test_names2 "c.indp2#c.indf1#c.FD_temp1 c.indp2#c.indf1#c.FD_temp2"

. 
. di ""


. di "Checking with indp2 instead:"
Checking with indp2 instead:

. foreach tn of local test_names2 {
  2.     local found = 0
  3.     foreach nm of local names {
  4.         if "`nm'" == "`tn'" {
  5.             local found = 1
  6.         }
  7.     }
  8.     
.     if `found' {
  9.         di "✓ FOUND: `tn'"
 10.     }
 11.     else {
 12.         di "✗ MISSING: `tn'"
 13.     }
 14. }
✓ FOUND: c.indp2#c.indf1#c.FD_temp1
✓ FOUND: c.indp2#c.indf1#c.FD_temp2

. 
. di ""


